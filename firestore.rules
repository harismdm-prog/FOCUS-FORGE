rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().keys().hasAll(['id', 'email', 'name', 'xp', 'level', 'streak'])
        && incoming().id == userId
        && incoming().email is string
        && incoming().name is string
        && incoming().xp == 0
        && incoming().level == 1;
      
      allow update: if isOwner(userId) && (
        // Action: Update Settings
        (incoming().diff(existing()).affectedKeys().hasOnly(['settings'])) ||
        // Action: Update Stats (Session Completion)
        (incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'level', 'streak', 'lastSessionDate']))
      );
    }

    // --- Sessions ---
    match /sessions/{sessionId} {
      function isValidSession(data) {
        return data.userId == request.auth.uid
          && data.duration is number
          && data.completed is bool
          && data.date is string;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSession(incoming());
    }

    // --- Blocked Sites ---
    match /blockedSites/{siteId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().url is string;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Blocked Apps ---
    match /blockedApps/{appId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().name is string;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Blocked Mobile Apps ---
    match /blockedMobileApps/{appId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().name is string;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
